  "version": "0.2.0",
  "configurations": [
    {
      "name": "NestJS Debbuger",
      "type": "node",
      "request": "attach",
      "timeout": 10000,
      "restart": {
        "delay": 5000,
        "maxAttempts": 10
      },
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**/*.js"
      ]
    }
  ]
}
